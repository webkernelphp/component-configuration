{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "webkernel/standard-configuration",
    "description": "Runtime configuration injection engine for Webkernel. Allows modules to extend auth, database, and mail config without touching host application files.",
    "version": "0.1.0",
    "homepage": "https://www.webkernelphp.com/",
    "type": "library",
    "license": "EPL-2.0",
    "authors": [
        {
            "name": "El Moumen Yassine",
            "email": "yassine@numerimondes.com",
            "homepage": "https://webkernelphp.com/about"
        }
    ],
    "support": {
        "issues": "https://github.com/webkernelphp/standard-configuration/issues"
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Webkernel\\StdConf\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webkernel\\StdConf\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webkernel\\StdConf\\Providers\\StdConfServiceProvider"
            ]
        },
        "webkernel": {
            "package_repo": "git@github.com:webkernelphp/standard-configuration.git",
            "prefix": "standard-conf"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
